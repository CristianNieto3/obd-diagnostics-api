{
  "info": {
    "_postman_id": "b58d2bf1-a109-4d81-bac9-e36d4d7cb2f8",
    "name": "PulseOBD Vehicle Endpoints",
    "description": "CRUD tests for the PulseOBD vehicle API. Import this collection with the PulseOBD Local environment, then run requests in order.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Create Vehicle",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"status is 201 Created\", function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test(\"response has vehicle fields\", function () {",
              "    const body = pm.response.json();",
              "    pm.expect(body).to.have.property(\"id\");",
              "    pm.expect(body.vin).to.eql(\"1HGCM82633A004352\");",
              "    pm.expect(body.make).to.eql(\"Honda\");",
              "    pm.expect(body.model).to.eql(\"Accord\");",
              "    pm.expect(body.year).to.eql(2003);",
              "});",
              "",
              "const created = pm.response.json();",
              "pm.environment.set(\"vehicleId\", created.id);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"vin\": \"1HGCM82633A004352\",\n  \"make\": \"Honda\",\n  \"model\": \"Accord\",\n  \"year\": 2003\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/vehicle",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "vehicle"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Get All Vehicles",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"status is 200 OK\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"response is an array\", function () {",
              "    const body = pm.response.json();",
              "    pm.expect(body).to.be.an(\"array\");",
              "});",
              "",
              "pm.test(\"created vehicle appears in list\", function () {",
              "    const vehicleId = Number(pm.environment.get(\"vehicleId\"));",
              "    const body = pm.response.json();",
              "    pm.expect(body.some(vehicle => vehicle.id === vehicleId)).to.eql(true);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/vehicle",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "vehicle"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Get Vehicle By Id",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"status is 200 OK\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"returns requested vehicle\", function () {",
              "    const vehicleId = Number(pm.environment.get(\"vehicleId\"));",
              "    const body = pm.response.json();",
              "    pm.expect(body.id).to.eql(vehicleId);",
              "    pm.expect(body.vin).to.eql(\"1HGCM82633A004352\");",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/vehicle/{{vehicleId}}",
